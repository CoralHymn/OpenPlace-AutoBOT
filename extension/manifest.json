{
  "manifest_version": 3,
  "name": "WPlace AutoBOT",
  "version": "2.0.0",
  "description": "WPlace AutoBOT - Automation toolkit for wplace.live. Supports Farm, Guard, Image, Launcher, and Slave modes.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://wplace.live/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://wplace.live/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WPlace AutoBOT",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["bots/*.js"],
      "matches": ["https://wplace.live/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "wplace-autobot@alarisco.com",
      "strict_min_version": "109.0"
    }
  }
}